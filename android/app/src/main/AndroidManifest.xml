<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
package="com.aquagrow.app">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:screenOrientation="portrait"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:showOnLockScreen="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ── Firebase Phone Auth reCAPTCHA redirect ────────────────────
                 When SafetyNet / Play Integrity cannot silently verify the
                 device (e.g. debug APK, sideloaded, emulator), Firebase falls
                 back to browser-based reCAPTCHA. After the user completes the
                 challenge the browser redirects back to the app via the custom
                 scheme:  com.aquagrow.app://__/auth/handler
                 Without this filter Android shows a "Open with browser" picker
                 and the deep-link never reaches the app — the OTP flow hangs.
            ─────────────────────────────────────────────────────────────── -->
            <intent-filter android:label="firebase_auth_redirect">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- Scheme must match the applicationId exactly -->
                <data android:scheme="com.aquagrow.app" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!--
             AquaGrowMessagingService — custom FCM handler.

             Priority 0 means Android routes the MESSAGING_EVENT to our service
             FIRST, before any Capacitor internal handler (which sits at -500).

             This is the critical piece for killed-state notifications:
             — With a "notification" payload key, Android auto-displays the
               notification (system-rendered) without waking Capacitor.
             — With a DATA-ONLY payload, Android wakes this service and we
               build+post the notification manually.
             — Either way the farmer sees the alert even if the app is force-killed.
        -->
        <service
            android:name=".AquaGrowMessagingService"
            android:exported="false">
            <intent-filter android:priority="0">
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ── FCM Default Notification Icon ─────────────────────────────────
             Tells FCM which drawable to use as the small icon when no icon is
             specified in the notification payload.  Must be a single-color
             white drawable (ic_stat_aquagrow.xml in res/drawable/).
             Without this, FCM on Android 5+ may silently drop notifications.
        ──────────────────────────────────────────────────────────────────── -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_aquagrow" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/colorPrimary" />
        <!-- Default channel for FCM messages that dont specify a channelId -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="aquagrow-premium" />

    </application>

    <!-- ── Core app permissions ── -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Photo / Gallery access -->
    <!-- Android 13+ (API 33) — granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- ── Push Notification permissions ── -->
    <!-- Required on Android 13+ (API 33) — without this notifications are silently blocked -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keeps Firebase subscription alive across device reboots -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Allows notification vibration on lock screen -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Prevents CPU from sleeping when a high-priority FCM message arrives -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Allows prompting user to exclude app from battery optimisation
         (critical for reliable background FCM on MIUI / One UI / OxygenOS) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Required to show notifications in background/foreground services on Android 9+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required for exact-time LocalNotifications on Android 12+ (API 31+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Allows notification to appear on lock screen (keyguard) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

</manifest>
