<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- App running theme: no action bar, transparent background (Capacitor web view) -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        
        <!-- Android Ergonomics: Make status bar icons dark for white header comfort -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#00000000</item>

        <!-- Android Ergonomics: Match bottom nav bar to app background -->
        <item name="android:navigationBarColor">#F8F9FE</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!--
        Launch / Splash theme:
        Uses the branded AquaGrow amber XML drawable instead of the plain
        white Capacitor default png. The drawable fills the screen with the
        gold gradient + centered icon, matching the in-app SplashScreen.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@color/ic_launcher_background</item>
        <item name="android:windowBackground">@color/ic_launcher_background</item>
        <item name="android:statusBarColor">@color/ic_launcher_background</item>
        <item name="android:navigationBarColor">@color/ic_launcher_background</item>
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <!-- Remove white flash between native splash and web view -->
        <item name="android:windowIsTranslucent">false</item>
    </style>

</resources>