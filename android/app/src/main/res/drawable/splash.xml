<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background: AquaGrow amber gold gradient approximation (solid) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="200%"
                android:startColor="#E09400"
                android:centerColor="#C78200"
                android:endColor="#8B5A00"
                android:angle="135" />
        </shape>
    </item>

    <!-- Subtle radial glow at center -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#22FFD060" />
            <size android:width="600dp" android:height="600dp" />
        </shape>
        <inset
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="300dp" />
    </item>

    <!-- Brand logo centered -->
    <item
        android:gravity="center"
        android:bottom="120dp">
        <layer-list>
            <!-- Icon rounded card background -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="40dp" />
                    <solid android:color="#22FFFFFF" />
                    <size android:width="160dp" android:height="160dp" />
                </shape>
            </item>
            <!-- App icon (mipmap) -->
            <item android:drawable="@mipmap/ic_launcher_foreground" />
        </layer-list>
    </item>

    <!-- App name text area placeholder (handled in web layer) -->

</layer-list>
